# ─────────────────────────────────────────────────────────────────
# Crypto AutoTrade Bot — Environment Config
# ─────────────────────────────────────────────────────────────────
# NEVER share this file or commit it to git.
# Add .env to your .gitignore immediately.

# Get your keys from Binance → Account → API Management
# For safety, restrict the API key to:
#   - Enable Spot Trading
#   - Restrict to your IP address
#   - Do NOT enable withdrawals

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# PORT for the local server (default 3001)
PORT=3001

# MODE: paper = no real orders sent | live = real orders on Binance
MODE=paper
